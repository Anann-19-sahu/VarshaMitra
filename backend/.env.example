# Runtime mode: dev or prod
ENV=dev

# Auth DB (supports SQLite or PostgreSQL)
# SQLite example:
AUTH_DATABASE_URL=sqlite:///./varsha_auth.db
# PostgreSQL example:
# AUTH_DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/varsha_auth

# JWT
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# OTP
OTP_EXPIRE_MINUTES=10
OTP_LENGTH=6

# SMTP (required when ENV=prod for email OTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
